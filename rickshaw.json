{
    "rickshaw-tool": {
        "schema": {
            "version": "2020.03.18"
        }
    },
    "tool": "dpdk",
    "controller": {
        "post-script": "%tool-dir%dpdk-post-process"
    },
    "collector": {
        "files-from-controller": [
            {
                "src": "%tool-dir%/dpdk-start",
                "dest": "/usr/bin/"
            },
            {
                "src": "%tool-dir%/dpdk-stop",
                "dest": "/usr/bin/"
            },
            {
                "src": "%tool-dir%/dpdk-collect",
                "dest": "/usr/bin/"
            },
            {
                "src": "%tool-dir%/dpdk_telemetry_client.py",
                "dest": "/usr/bin/"
            },
            {
                "src": "%tool-dir%/profiles",
                "dest": "/usr/bin/"
            }
        ],
        "blacklist": [
            {
                "endpoint": "remotehosts",
                "collector-types": [ "client", "server" ]
            },
            {
                "endpoint": "kube",
                "collector-types": [ "client", "server" ]
            }
        ],
        "whitelist": [
            {
                "endpoint": "osp",
                "collector-types": [ "compute" ]
            },
            {
                "endpoint": "remotehosts",
                "collector-types": [ "profiler" ]
            },
            {
                "endpoint": "kube",
                "collector-types": [ "profiler" ]
            }
        ],
        "start": "dpdk-start",
        "stop": "dpdk-stop"
    }
}
